{
  "manifest_version": 3,
  "name": "Pornhub Shorties Downloader Helper",
  "version": "1.0",
  "description": "一键转换并下载 Pornhub Shorties 短视频，提供 embed 链接与 yt-dlp 快速下载命令",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "nativeMessaging",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.pornhub.com/shorties/*",
        "*://*.pornhub.premium/shorties/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
