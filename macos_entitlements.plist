<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow loading dynamic libraries (incl. our bundled Python3.framework)
         even though they're only ad-hoc-signed. Required for Hardened Runtime
         when not using a paid Developer ID. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- PyInstaller's bootloader needs to map RW+X memory for the embedded
         interpreter; without this entitlement Hardened Runtime kills it. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- yt-dlp/ffmpeg subprocesses sometimes use DYLD_* env vars. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
